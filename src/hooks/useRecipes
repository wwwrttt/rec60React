// /src/hooks/useRecipes.js
import { useEffect } from 'react';
import { useRecipeStore } from '../store/recipeStore';

export function useRecipes() {
    const {
        recipes,
        pagination,
        loading,
        error,
        fetchRecipes,
        createRecipe,
        updateRecipe,
        deleteRecipe
    } = useRecipeStore();

    useEffect(() => {
        if (!recipes.length) {// Only fetch if empty (prevents refetch on navigation)
            fetchRecipes();
        }
    }, []);

    return {
        recipes,
        pagination,
        loading,
        error,
        fetchRecipes,
        createRecipe,
        updateRecipe,
        deleteRecipe
    };
}
